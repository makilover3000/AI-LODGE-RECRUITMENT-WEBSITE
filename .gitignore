# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code local config
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# AI Lodge — working/temp artifacts (not for the repo)
# (gitignore has no inline comments — keep notes on their own lines)
# QA screenshot cache
/.shots/
# stray screenshots/downloads dumped in repo root (real assets live in public/)
/*.png
# manually-downloaded reference images
/ChatGPT Image*
# standalone previews, now integrated into the app
/entry-demo.html
/smoke-title-demo.html
# stray preview exports dumped in repo root
/*.webp
# raw captain source photos — only the cropped /public/captains/*.jpg are committed
/vampire lodge pics/
/llm lodge pics/
/HacKStreet Boys PICS/
/kag lodge pics/
/wss lodge pics/
/cjb lodge pic/
/vercel pic/
# heavy AI-gen source originals — commit the optimized .jpg only
public/entry/*.png
# lodge logo source art — commit only the baked masks in public/logos/
/logos/
# past-moment source photos — commit only the optimized public/moments/*.webp
/ai-lodge-past-images/
# phone QA screenshots dropped in the repo root — local only
/screenshots of mobile/
# Nano Banana generation review set — reference only, never served
/asset-review/
# markdown notes — keep local only, do not track (README.md stays tracked)
*.md
!README.md
