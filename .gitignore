# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code local config
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# AI Lodge — working/temp artifacts (not for the repo)
# (gitignore has no inline comments — keep notes on their own lines)
# QA screenshot cache
/.shots/
# stray screenshots/downloads dumped in repo root (real assets live in public/)
/*.png
# manually-downloaded reference images
/ChatGPT Image*
# standalone previews, now integrated into the app
/entry-demo.html
/smoke-title-demo.html
# heavy AI-gen source originals — commit the optimized .jpg only
public/entry/*.png
